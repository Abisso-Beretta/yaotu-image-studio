{
  "name": "theme-background-generator",
  "version": "0.1.4",
  "private": true,
  "description": "妖荼: a local GPT Image background generator.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abisso-Beretta/yaotu-image-studio.git"
  },
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js && node --check public/app.js && node --check public/manju.js && node --check desktop/main.js",
    "desktop": "electron .",
    "build:ui": "cd app && npm install && npm run build",
    "build:dir": "npm run build:ui && electron-builder --dir --win --x64 --publish never",
    "build:exe": "npm run build:ui && electron-builder --win portable --x64 --publish never",
    "build:installer": "npm run build:ui && electron-builder --win nsis --x64 --publish never --config.directories.output=dist-installer",
    "release:github": "npm run build:ui && electron-builder --win nsis portable --x64 --publish always --config.directories.output=dist-installer",
    "release": "node scripts/release.mjs",
    "tauri:exe": "npm run build:exe"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "local.yaotu.workbench",
    "productName": "妖荼",
    "directories": {
      "app": ".",
      "output": "dist"
    },
    "files": [
      "server.js",
      "package.json",
      "public/**/*",
      "app/dist/**/*",
      "desktop/**/*",
      "!api-profiles.json",
      "!.env",
      "!outputs/**/*",
      "!dist/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Abisso-Beretta",
        "repo": "yaotu-image-studio",
        "releaseType": "release"
      }
    ],
    "win": {
      "compression": "store",
      "icon": "desktop/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false,
      "signDlls": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "YaoTu-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "妖荼",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "YaoTu-${version}-${arch}.${ext}",
      "requestExecutionLevel": "user",
      "useZip": true,
      "unpackDirName": "YaoTu"
    }
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "25.1.8"
  }
}
